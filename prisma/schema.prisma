// This block tells Prisma to generate the TypeScript Client for you
generator client {
  provider = "prisma-client-js"
}

// This block connects your models to your actual PostgreSQL database
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// --- Enums ---

enum UserRole {
  ADMIN
  PARENT
  INSTRUCTOR
}

// --- Models ---

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // Hashed!
  name      String // 👈 Combined field
  role      UserRole @default(PARENT)
  createdAt DateTime @default(now())

  isEmailVerified   Boolean  @default(false)
  verificationToken String?  @unique

  whatsappNumber String?
  phoneNumber    String?
  affiliatedChurch String?
  homeAddress    String?

  sentBroadcasts   Broadcast[] @relation("SentBroadcasts")

  // Relations
  children     Child[]
  applications Application[]
  dismissalContacts DismissalContact[]
}

model Child {
  id        String   @id @default(uuid())
  firstName String // 👈 Split
  lastName  String // 👈 Split
  sex       Sex     @default(MALE)
  dob       DateTime
  photoUrl  String? // 👈 Stores the public S3 URL
  createdAt DateTime @default(now())

  parentId      String
  parent        User           @relation(fields: [parentId], references: [id])
  registrations Registration[]
}

enum SessionStatus {
  DRAFT
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ACTIVE
  COMPLETED
}

model Session {
  id            String         @id @default(uuid())
  name          String // e.g., "Summer Explorer 2026"
  theme         String         @default("") 
  status        SessionStatus  @default(DRAFT)
  startDate     DateTime
  endDate       DateTime
  isClassVisible Boolean       @default(false)
  isActive      Boolean        @default(false)
  classes       Class[]
  registrations Registration[]
  applications  Application[]

  // High-level metadata for the session
  pricePerClass Decimal
  maxCapacity   Int

  createdAt DateTime @default(now())
}

model Class {
  id        String  @id @default(uuid())
  name      String // e.g., "Lions Section"
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  registrationsCount Int @default(0)

  // 🔗 Lineage tracking: Keeps track of which class this was cloned from
  clonedFromId String?
  isVisible    Boolean @default(true)
  price        Decimal? @db.Decimal(10,2)

  // 👥 Text Array Optimization
  instructorIds String[] // Array of User UUIDs

  capacity Int
  ageMin   Int
  ageMax   Int

  registrations Registration[]

  createdAt DateTime @default(now())

  @@index([sessionId])
}

// --------------------------------------
// ENUMS for Type Safety
// --------------------------------------

enum ApplicationStatus {
  PENDING // Created, but payment not confirmed
  COMPLETED // Payment successful, spot confirmed
  PARTIALLY_PAID
  EXPIRED // Time-to-pay exceeded, spot released
  CANCELLED // Manually retracted by parent/admin
}

enum PaymentPlan {
  FULL
  PARTIAL
}

enum Sex {
  MALE
  FEMALE
}

// --------------------------------------
// MODELS
// --------------------------------------

model Application {
  id       String @id @default(cuid())
  parentId String
  parent   User   @relation(fields: [parentId], references: [id])

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  status      ApplicationStatus @default(PENDING)
  paymentPlan PaymentPlan

  // Track total amounts at the time of creation
  totalAmount Decimal @db.Decimal(10, 2)

  amountPaid Decimal @default(0) @db.Decimal(10,2)
  balanceDue Decimal @default(0) @db.Decimal(10,2)

  registrations Registration[]
  payments      Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, sessionId, status])
}

model Registration {
  id String @id @default(cuid())

  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])

  childId String
  child   Child  @relation(fields: [childId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  // Specific status for individual child placement
  status RegistrationStatus @default(PROVISIONAL)

  createdAt DateTime @default(now())

  @@unique([childId, classId, applicationId]) // Prevent duplicate placement in same app
}

enum RegistrationStatus{
  PROVISIONAL
  CONFIRMED
  CANCELLED
}

enum PaymentStatus {
  PENDING // Transaction initiated but not yet successful
  SUCCESSFUL // Money is in the bank
  FAILED // Transaction declined
  REFUNDED // Money returned to parent
  EXPIRED
}

enum PaymentMethod {
  STRIPE
  PAYSTACK
  BANK_TRANSFER
  CASH
}

model Payment {
  id String @id @default(cuid())

  // Link to the Application (The "Invoice")
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])

  // Financial Data
  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("USD")
  status   PaymentStatus @default(PENDING)
  method   PaymentMethod

  // External Reference (e.g., Stripe PI ID or Paystack Ref)
  // Crucial for reconciling with the payment gateway
  externalReference String? @unique

  // Metadata
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([applicationId, status])
}

model DismissalContact {
  id           String   @id @default(uuid())

  userId       String
  user         User     @relation(fields: [userId], references: [id])

  name         String
  relationship String
  phone        String?

  createdAt    DateTime @default(now())
}

// --- New Broadcast Model ---

enum BroadcastStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum BroadcastType {
  EMAIL
  SMS
}

model Broadcast {
  id         String          @id @default(cuid())
  type       BroadcastType
  status     BroadcastStatus @default(PROCESSING)
  
  // Content details
  subject    String?         // Used for Emails
  content    String          @db.Text
  
  // Metrics
  recipients Int             @default(0)
  
  // Admin who sent it
  senderId   String
  sender     User            @relation("SentBroadcasts", fields: [senderId], references: [id])

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([senderId])
}
