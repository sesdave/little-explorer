{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "../../dist/apps/portal-api",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "baseUrl": "../../",

    "types": ["node", "multer"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}