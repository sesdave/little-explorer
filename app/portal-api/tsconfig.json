{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "multer"],
    /* 🛡️ New for TS 6.0: Silence the deprecation warnings */
    "ignoreDeprecations": "6.0",
    
    /* 🛠️ Modernize the resolution for Node.js */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    
    /* 📁 Standard NestJS paths */
    "outDir": "../../dist/apps/portal-api",
    "rootDir": "src",
    "noEmit": false,
    
    /* ✨ Mandatory for NestJS Dependency Injection */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    
    /* 📦 Compatibility fixes */
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}