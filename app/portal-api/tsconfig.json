{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "multer"],
    "ignoreDeprecations": "6.0",

    /* Node runtime */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* ✅ FIX: widen rootDir */
    "rootDir": "../../",

    /* output */
    "outDir": "../../dist/apps/portal-api",
    "noEmit": false,

    /* NestJS */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    /* compatibility */
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  /* ✅ FIX: include shared-types */
  "include": [
    "src/**/*",
    "../shared-types/src/**/*"
  ],

  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}